# SecureCode AI Environment Configuration

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/securecode
REDIS_URL=redis://localhost:6379/0

# ML Model Configuration
MODEL_PATH=models/securecode-v1
MODEL_DEVICE=cpu
MODEL_MAX_LENGTH=512

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# GitHub Integration
GITHUB_TOKEN=your_github_token_here
GITHUB_API_URL=https://api.github.com

# CVE/NVD API
NVD_API_KEY=your_nvd_api_key
NVD_API_URL=https://services.nvd.nist.gov/rest/json

# Security
SECRET_KEY=change_this_to_a_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
ENABLE_TEST_GENERATION=true
ENABLE_REMEDIATION=true
ENABLE_XAI=true
ENABLE_CONTINUOUS_LEARNING=false